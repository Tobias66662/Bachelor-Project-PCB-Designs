	)
	(text "Uncertainties:\n- We Haven't yet decided on what \n   Leds or NTC thermistor to use\n- Should I add more bulk decoupling?\n"
		(exclude_from_sim no)
		(at 244.094 -11.176 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "497bc61a-605d-4ab1-abd5-604596dbb2f2")
	)
	(text "3.3V Buck-Boost Converter"
		(exclude_from_sim no)
		(at 45.72 186.182 0)
		(effects
			(font
				(size 2 2)
				(thickness 0.4)
				(bold yes)
			)
		)
		(uuid "4de1bea7-c55c-4ef1-9911-6f38c1ef5ca4")
	)
	(text "Note:\n- The thermistor has not yet been selected.\n- Due to DC bias effects in 0805 MLCC capacitors, additional capacitance has been added\n   to maintain the required effective capacitance.\n- The buck-boost converter starts automatically at power-up, while the boost converter is enabled by the ESP32\n- +SYS is the output of battery and charger, while +VBAT it the output of the load switch IC"
		(exclude_from_sim no)
		(at 177.8 173.228 0)
		(effects
			(font
				(size 1.2 1.2)
				(thickness 0.3)
				(bold yes)
			)
			(justify left)
		)
		(uuid "6dabbfa2-9ed0-4f5f-86ba-f34039295685")
	)
